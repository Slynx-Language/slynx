import std;
stylesheet A() {
    styles {
        foregroundColor: Color(inner:0xff0000)
    }
}

stylesheet B() {
    styles {
        backgroundColor: Color(inner:0x0000ff)
    }
}
component Div {}
component Text {
    pub prop text:str;
}
stylesheet C() uses A(), B() {}

component Root {
    Div {
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
