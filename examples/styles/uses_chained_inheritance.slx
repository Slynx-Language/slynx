import std;
stylesheet A() {
    styles {
        foregroundColor: Color(inner:0xff0000),
    }
}

stylesheet B() uses A() {
    styles {
        backgroundColor: Color(inner:0x00ff00),
    }
}

stylesheet C() uses B() {
    styles {
        foregroundColor: Color(inner:0x0000ff)
    }
}

component Root {
    Div {
        style: C(),
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
