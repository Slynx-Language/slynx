import std;
stylesheet Fg(color: int) {
    styles {
        foregroundColor: Color(inner:color)
    }
}

stylesheet Bg() uses Fg(0x00ffff) {
    styles {
        backgroundColor: Color(inner:0x0000ff)
    }
}

component Root {
    Div {
        style: Bg(),
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
