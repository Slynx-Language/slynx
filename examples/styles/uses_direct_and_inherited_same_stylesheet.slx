import std;
stylesheet Fg(color: int) {
    styles {
        foregroundColor: Color(inner:color)
    }
}

stylesheet Bg(color: int) uses Fg(color - 0x00ffff) {
    styles {
        backgroundColor: Color(inner:color)
    }
}
component Div {}
component Text {
    pub prop text:str;
}
component A {
    Div {

        Text {
            text: "direct"
        }
    }
}

component B {
    Div {

        Text {
            text: "inherited"
        }
    }
}

func main(): Component {
    A {}
}
