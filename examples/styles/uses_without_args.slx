import std using Color;
stylesheet Base() {
    styles {
        foregroundColor: Color(inner:0xff0000)
    }
}

stylesheet Derived() uses Base() {
    styles {
        backgroundColor: Color(inner:0x00ff00)
    }
}

component Root {
    Div {
        style: Derived(),
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
