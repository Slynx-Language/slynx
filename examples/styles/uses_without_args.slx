import std using Color;
stylesheet Base() {
    styles {
        foregroundColor: Color(inner:0xff0000)
    }
}

stylesheet Derived() uses Base() {
    styles {
        backgroundColor: Color(inner:0x00ff00)
    }
}
component Div {}
component Text {
    pub prop text:str;
}
component Root {
    Div {

        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
