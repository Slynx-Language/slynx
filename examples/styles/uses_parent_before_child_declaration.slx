import std;
stylesheet Child() uses Parent() {
    styles {
        backgroundColor: Color(inner:0x0000ff)
    }
}

stylesheet Parent() {
    styles {
        foregroundColor: Color(inner:0xff0000)
    }
}

component Root {
    Div {
        style: Child(),
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
