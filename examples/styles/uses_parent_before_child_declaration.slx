import std;
stylesheet Child() uses Parent() {
    styles {
        backgroundColor: Color(inner:0x0000ff)
    }
}

stylesheet Parent() {
    styles {
        foregroundColor: Color(inner:0xff0000)
    }
}
component Div {}
component Text {
    pub prop text:str;
}
component Root {
    Div {
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
